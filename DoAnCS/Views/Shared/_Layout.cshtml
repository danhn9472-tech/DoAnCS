﻿
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebBanHang</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
            :root {
                /* Định nghĩa bảng màu chuyên nghiệp */
                --bg-body: #f0f2f5; /* Màu nền tổng thể (xám xanh dịu) */
                --bg-nav: #ffffff; /* Màu nền Navbar */
                --primary-color: #4e73df; /* Màu xanh thương hiệu */
                --text-main: #3a3b45; /* Màu chữ chính */
            }

            body {
                font-family: 'Inter', sans-serif;
                background-color: var(--bg-body); /* Áp dụng màu nền mới */
                color: var(--text-main);
                display: flex;
                flex-direction: column;
                min-height: 100vh;
            }

            /* Navbar với hiệu ứng kính mờ (Glassmorphism) nhẹ */
            .navbar {
                background-color: rgba(255, 255, 255, 0.95) !important;
                backdrop-filter: blur(10px); /* Làm mờ nhẹ phần nền phía sau khi cuộn */
                box-shadow: 0 1px 15px rgba(0,0,0,0.05);
                padding: 0.7rem 0;
            }

            .navbar-brand {
                font-weight: 800;
                color: var(--primary-color) !important;
                letter-spacing: -0.5px;
            }

            /* Các liên kết trên menu */
            .nav-link {
                font-weight: 500;
                color: #5a5c69 !important;
                padding: 0.5rem 1.2rem !important;
                border-radius: 8px;
                transition: all 0.2s ease-in-out;
            }

                .nav-link:hover {
                    background-color: rgba(78, 115, 223, 0.1);
                    color: var(--primary-color) !important;
                }

            /* Padding cho phần nội dung chính để cân đối với background */
            .main-container {
                flex: 1;
                padding-top: 2.5rem;
                padding-bottom: 4rem;
            }

            /* Footer đồng bộ màu nền */
            footer {
                background-color: #ffffff;
                padding: 2rem 0;
                border-top: 1px solid #e3e6f0;
                margin-top: auto;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-bag-check-fill me-2"></i>WebBanHang
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Recipe" asp-action="Index">
                                <i class="bi bi-box-seam me-1"></i>Công Thức
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Tip" asp-action="Index">
                                <i class="bi bi-tags me-1"></i>Tips
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="CaloCaculate" asp-action="Index">
                                <i class="bi bi-tags me-1"></i>Tính Calo
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center">
                        <a href="#" class="nav-link me-3"><i class="bi bi-search"></i></a>
                        <a href="#" class="nav-link me-3 position-relative">
                            <i class="bi bi-cart3"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                0
                            </span>
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="text-center">
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <p class="mb-1">&copy; 2026 - <span class="fw-bold text-primary">WebBanHang</span>. All rights reserved.</p>
                    <div class="small">
                        <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted mx-2">Chính sách bảo mật</a>
                        <a href="#" class="text-decoration-none text-muted mx-2">Điều khoản sử dụng</a>
                        <a href="#" class="text-decoration-none text-muted mx-2">Liên hệ</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>