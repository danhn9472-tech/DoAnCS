@{
    ViewData["Title"] = "Chi tiết món ăn - NutriCook";
}

<style>
    /* Tổng thể trang chi tiết */
    .recipe-header {
        margin-top: 2rem;
        margin-bottom: 3rem;
    }

    .recipe-title-main {
        font-weight: 800;
        color: var(--color-darkest);
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }

    /* Hình ảnh món ăn */
    .recipe-main-img {
        width: 100%;
        border-radius: 24px;
        object-fit: cover;
        max-height: 500px;
        box-shadow: 0 20px 40px rgba(15, 42, 29, 0.1);
    }

    /* Bảng thông tin nhanh (Quick Info) */
    .quick-info-box {
        background: var(--white);
        border: 1px solid var(--color-pale);
        border-radius: 20px;
        padding: 1.5rem;
        display: flex;
        justify-content: space-around;
        text-align: center;
        margin-top: -50px;
        position: relative;
        width: 90%;
        margin-left: auto;
        margin-right: auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .info-item i {
        color: var(--color-medium);
        font-size: 1.5rem;
        display: block;
        margin-bottom: 5px;
    }

    /* Giá trị dinh dưỡng (Nutrition Card) */
    .nutrition-card {
        background-color: var(--color-darkest);
        color: var(--color-pale);
        border-radius: 20px;
        padding: 2rem;
        position: static;
        top: 100px;
    }

    .nutrition-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin-top: 1.5rem;
    }

    .nutrition-item {
        background: rgba(255,255,255,0.1);
        padding: 10px;
        border-radius: 12px;
        text-align: center;
    }

    .nutrition-value {
        font-weight: 700;
        font-size: 1.2rem;
        display: block;
    }

    /* Danh sách nguyên liệu */
    .ingredient-list {
        list-style: none;
        padding: 0;
    }

    .ingredient-item {
        padding: 12px 0;
        border-bottom: 1px dashed var(--color-light);
        display: flex;
        justify-content: space-between;
    }

    /* Các bước thực hiện */
    .step-box {
        margin-bottom: 2rem;
        display: flex;
        gap: 20px;
    }

    .step-number {
        background: var(--color-medium);
        color: var(--white);
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-weight: 700;
    }

    /* Nút Lưu & Rating */
    .btn-save {
        border: 2px solid var(--color-medium);
        color: var(--color-medium);
        border-radius: 50px;
        padding: 8px 25px;
        transition: 0.3s;
    }

        .btn-save:hover, .btn-save.active {
            background: var(--color-medium);
            color: var(--white);
        }

    .rating-stars {
        color: #f1c40f;
        font-size: 1.2rem;
    }
</style>

<div class="container recipe-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/Recipe" class="text-decoration-none text-muted">Công thức</a></li>
            <li class="breadcrumb-item active" aria-current="page">Salad Ức Gà</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <h1 class="recipe-title-main">Salad Ức Gà Áp Chảo Sốt Chanh Dây</h1>
            
            <div class="d-flex align-items-center gap-4 mb-4">
                <div class="rating-stars">
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-half"></i>
                    <span class="text-muted small ms-2">(4.5/5 - 120 đánh giá)</span>
                </div>
                <button class="btn btn-save" id="saveRecipe">
                    <i class="bi bi-bookmark-heart"></i> Lưu công thức
                </button>
            </div>

            <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=1200" class="recipe-main-img" alt="Salad">

            <div class="quick-info-box">
                <div class="info-item">
                    <i class="bi bi-clock"></i>
                    <small class="text-muted">Thời gian</small>
                    <div class="fw-bold">25 Phút</div>
                </div>
                <div class="info-item">
                    <i class="bi bi-bar-chart"></i>
                    <small class="text-muted">Độ khó</small>
                    <div class="fw-bold">Dễ</div>
                </div>
                <div class="info-item">
                    <i class="bi bi-people"></i>
                    <small class="text-muted">Khẩu phần</small>
                    <div class="fw-bold">2 Người</div>
                </div>
            </div>

            <div class="mt-5">
                <h3 class="fw-bold mb-4 border-bottom pb-2">Các bước thực hiện</h3>
                
                <div class="step-box">
                    <div class="step-number">1</div>
                    <div class="step-content">
                        <h5 class="fw-bold">Sơ chế nguyên liệu</h5>
                        <p class="text-muted">Ức gà rửa sạch, thấm khô, khía nhẹ trên bề mặt để thấm gia vị. Rau xà lách, cà chua bi rửa sạch và để ráo nước.</p>
                    </div>
                </div>

                <div class="step-box">
                    <div class="step-number">2</div>
                    <div class="step-content">
                        <h5 class="fw-bold">Áp chảo ức gà</h5>
                        <p class="text-muted">Ướp gà với chút muối và tiêu. Làm nóng chảo với dầu ô liu, áp chảo mỗi mặt khoảng 5-7 phút cho đến khi chín vàng đều.</p>
                    </div>
                </div>

                <div class="step-box">
                    <div class="step-number">3</div>
                    <div class="step-content">
                        <h5 class="fw-bold">Làm sốt và trình bày</h5>
                        <p class="text-muted">Trộn cốt chanh dây với mật ong. Cắt gà thành miếng vừa ăn, xếp lên dĩa cùng rau củ và rưới nước sốt lên trên.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="nutrition-card mb-4">
                <h4 class="fw-bold mb-0">Giá trị dinh dưỡng</h4>
                <small class="opacity-75">(Dựa trên 1 khẩu phần ăn)</small>
                
                <div class="nutrition-grid">
                    <div class="nutrition-item">
                        <span class="nutrition-value text-warning">420</span>
                        <small>Kcal</small>
                    </div>
                    <div class="nutrition-item">
                        <span class="nutrition-value">35g</span>
                        <small>Protein</small>
                    </div>
                    <div class="nutrition-item">
                        <span class="nutrition-value">12g</span>
                        <small>Fat</small>
                    </div>
                    <div class="nutrition-item">
                        <span class="nutrition-value">25g</span>
                        <small>Carb</small>
                    </div>
                </div>
            </div>

            <div class="p-4 border rounded-4 bg-white shadow-sm">
                <h4 class="fw-bold mb-4">Nguyên liệu</h4>
                <ul class="ingredient-list">
                    <li class="ingredient-item">
                        <span><i class="bi bi-check2-circle me-2 text-success"></i>Ức gà tươi</span>
                        <span class="fw-bold">300g</span>
                    </li>
                    <li class="ingredient-item">
                        <span><i class="bi bi-check2-circle me-2 text-success"></i>Xà lách thủy canh</span>
                        <span class="fw-bold">100g</span>
                    </li>
                    <li class="ingredient-item">
                        <span><i class="bi bi-check2-circle me-2 text-success"></i>Cà chua bi</span>
                        <span class="fw-bold">50g</span>
                    </li>
                    <li class="ingredient-item">
                        <span><i class="bi bi-check2-circle me-2 text-success"></i>Chanh dây (Lấy cốt)</span>
                        <span class="fw-bold">2 quả</span>
                    </li>
                    <li class="ingredient-item">
                        <span><i class="bi bi-check2-circle me-2 text-success"></i>Dầu Ô liu</span>
                        <span class="fw-bold">10ml</span>
                    </li>
                    <li class="ingredient-item">
                        <span><i class="bi bi-check2-circle me-2 text-success"></i>Mật ong nguyên chất</span>
                        <span class="fw-bold">1 muỗng</span>
                    </li>
                </ul>
            </div>

            <div class="mt-4 p-3 rounded-4" style="background-color: var(--color-pale);">
                <small class="text-uppercase fw-bold text-muted d-block mb-2">Danh mục liên quan</small>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-white text-dark border">Healthy</span>
                    <span class="badge bg-white text-dark border">Bữa tối</span>
                    <span class="badge bg-white text-dark border">Giảm cân</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Xử lý nút lưu công thức
        document.getElementById('saveRecipe').addEventListener('click', function() {
            this.classList.toggle('active');
            if(this.classList.contains('active')) {
                this.innerHTML = '<i class="bi bi-bookmark-check-fill"></i> Đã lưu';
            } else {
                this.innerHTML = '<i class="bi bi-bookmark-heart"></i> Lưu công thức';
            }
        });
    </script>
}