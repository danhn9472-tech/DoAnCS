@{
    ViewData["Title"] = "Trang Chủ - NutriCook";
}

<style>
    /* 1. HERO SECTION */
    .hero-section {
        background: linear-gradient(135deg, var(--color-deep) 0%, var(--color-darkest) 100%);
        color: var(--white);
        padding: 80px 0;
        border-radius: 24px;
        margin-bottom: 3rem;
        box-shadow: 0 10px 30px rgba(15, 42, 29, 0.1);
    }

    .hero-title {
        font-weight: 800;
        font-size: 3rem;
        margin-bottom: 1.5rem;
    }

    .btn-custom {
        background-color: var(--color-light);
        color: var(--color-darkest);
        font-weight: 600;
        padding: 12px 30px;
        border-radius: 50px;
        border: none;
        transition: 0.3s;
        text-decoration: none;
        display: inline-block;
    }

        .btn-custom:hover {
            background-color: var(--white);
            transform: translateY(-3px);
            color: var(--color-deep);
        }

    /* 2. FEATURE CARDS */
    .feature-card {
        background: var(--white);
        border: 1px solid var(--color-pale);
        border-radius: 20px;
        padding: 30px;
        transition: 0.3s;
        height: 100%;
        text-align: center;
    }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(107, 144, 113, 0.15);
            border-color: var(--color-medium);
        }

    .feature-icon {
        font-size: 2.5rem;
        color: var(--color-medium);
        margin-bottom: 1.5rem;
        display: inline-block;
    }

    .feature-title {
        color: var(--color-deep);
        font-weight: 700;
        margin-bottom: 1rem;
    }

    /* 3. RECIPE HIGHLIGHT SECTION (MỚI THÊM) */
    .recipe-highlight {
        padding: 4rem 0;
    }

    .section-label {
        color: var(--color-medium);
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 2px;
        font-size: 0.85rem;
        margin-bottom: 0.5rem;
        display: block;
    }

    .section-title {
        color: var(--color-darkest);
        font-weight: 800;
        margin-bottom: 2.5rem;
        position: relative;
        display: inline-block;
    }

        .section-title::after {
            content: "";
            position: absolute;
            bottom: -8px;
            left: 0;
            width: 50px;
            height: 4px;
            background-color: var(--color-medium);
            border-radius: 2px;
        }

    /* Tối ưu Card cho trang chủ */
    .home-recipe-card {
        background: var(--white);
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid var(--color-pale);
        transition: 0.4s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .home-recipe-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 25px rgba(15, 42, 29, 0.1);
        }

    .home-recipe-img {
        width: 100%;
        aspect-ratio: 4/3;
        object-fit: cover;
    }

    .home-recipe-body {
        padding: 1.5rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .home-recipe-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--color-darkest);
        margin-bottom: 1rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 3rem; /* Đảm bảo 1 hay 2 dòng thì Card vẫn cao bằng nhau */
        line-height: 1.4;
    }

    .home-recipe-meta {
        margin-top: auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: var(--color-medium);
        font-size: 0.85rem;
        border-top: 1px solid var(--color-pale);
        padding-top: 1rem;
    }

    .recipe-badge {
        background-color: var(--color-pale);
        color: var(--color-deep);
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.75rem;
    }
</style>

<div class="container mt-4">
    <div class="hero-section text-center">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <span class="section-label" style="color: var(--color-light);">Sống khỏe mỗi ngày</span>
                <h1 class="hero-title">Dinh dưỡng lành mạnh cho cuộc sống tươi đẹp</h1>
                <p class="lead mb-4 opacity-75">Khám phá hàng ngàn công thức nấu ăn ngon, tính toán lượng calo chính xác và nhận những mẹo hữu ích cho sức khỏe của bạn.</p>
                <div class="d-flex justify-content-center gap-3">
                    <a asp-controller="Recipe" asp-action="Index" class="btn-custom">Khám phá ngay</a>
                    <a asp-controller="CaloCaculate" asp-action="Index" class="btn btn-outline-light rounded-pill px-4 py-2 fw-bold text-decoration-none">Tính Calo</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon"><i class="bi bi-book-half"></i></div>
                <h4 class="feature-title">Công thức đa dạng</h4>
                <p class="text-muted mb-0">Từ món chay đến món mặn, tất cả đều được cân bằng dinh dưỡng một cách khoa học.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon"><i class="bi bi-fire"></i></div>
                <h4 class="feature-title">Kiểm soát Calo</h4>
                <p class="text-muted mb-0">Công cụ tính toán giúp bạn quản lý cân nặng và năng lượng nạp vào dễ dàng hơn.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon"><i class="bi bi-chat-heart"></i></div>
                <h4 class="feature-title">Mẹo sức khỏe</h4>
                <p class="text-muted mb-0">Những kiến thức bổ ích về thực phẩm giúp bạn trở thành chuyên gia trong bếp.</p>
            </div>
        </div>
    </div>

    <div class="recipe-highlight">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <span class="section-label">Gợi ý hôm nay</span>
                <h2 class="section-title m-0">Công thức nổi bật</h2>
            </div>
            <a asp-controller="Recipe" asp-action="Index" class="text-decoration-none fw-bold" style="color: var(--color-deep);">
                Xem tất cả <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="home-recipe-card">
                    <img src="https://images.unsplash.com/photo-1512621776951-a57141f2eefd?w=600" class="home-recipe-img" alt="Salad">
                    <div class="home-recipe-body">
                        <h5 class="home-recipe-title">Salad Cầu Vồng Với Sốt Chanh Dây Dinh Dưỡng</h5>
                        <div class="home-recipe-meta">
                            <span><i class="bi bi-clock me-1"></i> 15 phút</span>
                            <span class="recipe-badge">Dễ làm</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="home-recipe-card">
                    <img src="https://images.unsplash.com/photo-1547592166-23ac45744acd?w=600" class="home-recipe-img" alt="Ức gà">
                    <div class="home-recipe-body">
                        <h5 class="home-recipe-title">Ức Gà Áp Chảo Mật Ong Và Tỏi Thơm Nức Mũi</h5>
                        <div class="home-recipe-meta">
                            <span><i class="bi bi-clock me-1"></i> 25 phút</span>
                            <span class="recipe-badge">Healthy</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="home-recipe-card">
                    <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=600" class="home-recipe-img" alt="Smoothie">
                    <div class="home-recipe-body">
                        <h5 class="home-recipe-title">Smoothie Bơ Đậu Phộng Và Chuối Năng Lượng</h5>
                        <div class="home-recipe-meta">
                            <span><i class="bi bi-clock me-1"></i> 10 phút</span>
                            <span class="recipe-badge">Đồ uống</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="p-5 mb-5 rounded-4" style="background-color: var(--color-light); opacity: 0.9;">
        <div class="container-fluid py-2">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h2 class="fw-bold" style="color: var(--color-darkest)">Bắt đầu hành trình của bạn?</h2>
                    <p class="col-md-12 fs-5 text-dark opacity-75">Tham gia cộng đồng NutriCook để nhận thông báo về những món ăn mới nhất.</p>
                </div>
                <div class="col-md-4 text-md-end">
                    <button class="btn btn-dark btn-lg px-5 rounded-pill fw-bold" type="button">Đăng ký ngay</button>
                </div>
            </div>
        </div>
    </div>
</div>