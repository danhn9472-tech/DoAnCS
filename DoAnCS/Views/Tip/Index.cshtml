@model List<Tip>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <span class="section-label">Mẹo hay</span>
            <h2 class="section-title m-0">Tips dinh dưỡng & nấu ăn</h2>
        </div>
        <a href="/Tip/Create" class="btn-add-tip">+ Thêm bài viết</a>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <a href="/Tip/Details/@item.Id" class="card-wrapper text-decoration-none">
                    <div class="card tip-card shadow-sm h-100">
                        <img src="@item.ImageUrl" class="card-img-top tip-img" alt="@item.Title" />

                        <div class="card-body d-flex flex-column">
                            <h5 class="fw-bold mb-2 tip-title">
                                @item.Title
                            </h5>

                            <span class="mb-3 tip-category">
                                <i class="bi bi-tag-fill me-1"></i>@item.Category
                            </span>

                            <div class="mt-auto d-flex justify-content-between align-items-center pt-3 border-top">
                                <small class="tip-date">
                                    <i class="bi bi-calendar3 me-1"></i>@item.CreatedAt.ToShortDateString()
                                </small>
                                <span class="tip-link-text">
                                    Đọc bài viết <i class="bi bi-arrow-right"></i>
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<style>
    /* WRAPPER ĐỂ NHẤP CHUỘT */
    .card-wrapper {
        display: block; /* Quan trọng: Thẻ a phải là block để bao trùm Card */
        height: 100%;
        color: inherit;
    }

    /* CARD NÂNG CẤP */
    .tip-card {
        border-radius: 20px;
        border: 2px solid var(--color-pale); /* Mặc định nhạt */
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        background-color: white;
    }

    /* HIỆU ỨNG HOVER TOÀN BỘ CARD */
    .card-wrapper:hover .tip-card {
        transform: translateY(-10px);
        box-shadow: 0 15px 35px rgba(15, 42, 29, 0.15) !important;
        border-color: var(--color-medium);
    }

    /* IMAGE */
    .tip-img {
        height: 220px;
        object-fit: cover;
        border-top-left-radius: 18px;
        border-top-right-radius: 18px;
    }

    /* TEXT */
    .tip-title {
        color: var(--color-darkest);
        line-height: 1.5;
        /* Giới hạn 2 dòng tiêu đề để card đều nhau */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 3rem;
    }

    .tip-category {
        color: var(--color-medium);
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .tip-date {
        color: #888;
        font-size: 0.85rem;
    }

    /* GIẢ LẬP LINK TEXT */
    .tip-link-text {
        color: var(--color-deep);
        font-weight: 700;
        font-size: 0.9rem;
        transition: 0.3s;
    }

    .card-wrapper:hover .tip-link-text {
        color: var(--color-medium);
        padding-right: 5px;
    }

    /* BUTTON ADD */
    .btn-add-tip {
        border: 2px solid var(--color-medium);
        color: var(--color-deep);
        padding: 10px 25px;
        border-radius: 50px;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
        background: white;
    }

        .btn-add-tip:hover {
            background-color: var(--color-darkest);
            color: var(--color-pale);
            border-color: var(--color-darkest);
        }
</style>